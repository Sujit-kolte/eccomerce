{
  "name": "ecommerce-mern",
  "version": "1.0.0",
  "description": "Full-stack MERN E-Commerce Platform",
  "main": "api/index.js",
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd .. && cd server && npm install && cd ..",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm install && cd server && npm install && cd ../client && npm install && npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "dotenv": "^16.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "razorpay": "^2.8.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "ecommerce",
    "mern",
    "react",
    "node",
    "razorpay",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT"
}
