{
  "name": "ecommerce-mern",
  "version": "1.0.0",
  "description": "Full-stack MERN E-Commerce Platform",
  "main": "server/index.js",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd ..",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  },
  "keywords": [
    "ecommerce",
    "mern",
    "react",
    "node",
    "razorpay",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
